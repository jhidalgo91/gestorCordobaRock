# =====================================================
# VARIABLES DE ENTORNO — Córdoba Rock Agent
# =====================================================
# Copia este fichero a .env y rellena los valores.
# NUNCA subas el fichero .env a GitHub.
# En GitHub Actions estas vars van como Secrets.
# =====================================================

# --- WORDPRESS ---
WP_URL=https://cordobarock.es/wp-json
WP_USER=admin_mh
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- GOOGLE GEMINI AI ---
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash

# --- MODO PRUEBA Y CONTROL DE PUBLICACIÓN ---

# Número de items a procesar por ejecución.
#   N > 0 → primeros N items
#  -1     → todos
PUBLISH_LIMIT=-1

# Estado WP por defecto.
# "draft"   → Los posts quedan como BORRADOR (recomendado para producción hasta validar)
# "publish" → Se publican directamente
DEFAULT_WP_STATUS=draft

# Auto-publicar los primeros N items del lote; el resto quedan en borrador.
# 0 → desactivado, todos usan DEFAULT_WP_STATUS
# 1 → el primer item se publica, el resto son borradores
AUTO_PUBLISH_FIRST=0

# --- CONFIGURACIÓN AGENTE ---
DEFAULT_AI_TONE=periodistico
AGENT_SECRET_TOKEN=
