# =====================================================
# VARIABLES DE ENTORNO — Córdoba Rock Agent
# =====================================================
# Copia este fichero a .env y rellena los valores.
# NUNCA subas el fichero .env a GitHub.
# En GitHub Actions estas vars van como Secrets.
# =====================================================

# --- WORDPRESS ---
# URL base de la API REST de WordPress (sin barra final)
WP_URL=https://cordobarock.es/wp-json

# Usuario de WordPress con permisos de administrador
WP_USER=admin_mh

# Contraseña de Aplicación de WordPress
# (NO es la contraseña de login. Ve a: WP Admin > Perfil > Contraseñas de Aplicación)
# ⚠️  ROTA ESTA CONTRASEÑA si el repo ha estado público
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- GOOGLE GEMINI AI ---
# Obtén tu clave en: https://aistudio.google.com/apikey
# ⚠️  ROTA ESTA CLAVE si el repo ha estado público
GEMINI_API_KEY=AIzaSy...

# Modelo de Gemini a usar (opcional, default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# --- CONFIGURACIÓN AGENTE ---
# Tono de redacción por defecto: periodistico | rockero | social
DEFAULT_AI_TONE=periodistico

# Token de seguridad para verificar llamadas entrantes (opcional)
# Genéralo con: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_SECRET_TOKEN=
